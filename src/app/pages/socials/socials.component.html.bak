<main class="mx-auto max-w-[var(--container)] px-3 pb-8 pt-3 sm:px-4 sm:pb-10">
	<section
		class="socials-shell overflow-hidden rounded-[1.4rem] border border-[var(--c-border)] bg-[var(--c-bg-secondary)] shadow-[var(--shadow-sm)]"
	>
		<div class="border-b border-[var(--c-border)] px-4 py-5 sm:px-6 sm:py-6">
			<p class="text-[12px] font-semibold uppercase tracking-[0.18em] text-[var(--c-secondary)]">
				<span [translate]="'Socials'">{{ 'Socials' }}</span>
			</p>
			<h1 class="mt-2 text-[1.8rem] font-semibold leading-9 text-[var(--c-text-secondary)]">
				<span [translate]="'Wake Cup contacts and social media'">{{
					'Wake Cup contacts and social media'
				}}</span>
			</h1>
			<p class="mt-2 max-w-[42rem] text-sm leading-6 text-[var(--c-text-muted)]">
				<span
					[translate]="'Contact Wake Cup cafe in Kamianets-Podilskyi for specialty coffee, pastries, takeaway coffee, reservations, and current social updates.'"
					>{{
						'Contact Wake Cup cafe in Kamianets-Podilskyi for specialty coffee, pastries, takeaway coffee, reservations, and current social updates.'
					}}</span
				>
			</p>
		</div>

		<div class="grid gap-4 p-4 lg:grid-cols-[minmax(0,1fr)_18rem_minmax(0,1fr)] lg:p-6">
			<div class="space-y-4">


				<div
					class="contact-card block rounded-[1.1rem] border border-[var(--c-border)] bg-[var(--c-bg-primary)] p-4 shadow-[var(--shadow-sm)]"
				>
					<div class="flex items-start gap-4">
						<span class="icon-wrap mt-1 inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-full text-xl font-semibold text-[var(--c-text-muted)]" aria-hidden="true">
							<svg
								class="h-6 w-6"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="1.5"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<path d="M12 21s7-6.3 7-12.5C19 5.46 16.54 3 13.5 3 10.46 3 8 5.46 8 8.5 8 14.7 15 21 15 21" />
								<circle cx="12" cy="8.5" r="2.5" />
							</svg>
						</span>
						<div class="min-w-0">
							<p class="text-[12px] font-semibold uppercase tracking-[0.18em] text-[var(--c-secondary)]">
								<span [translate]="'Address'">{{ 'Address' }}</span>
							</p>
							<p class="mt-2 text-lg font-semibold leading-7 text-[var(--c-text-secondary)]">
								проспект Грушевського, 31, Кам'янець-Подільський<br />
								Хмельницька область, 32303
							</p>
						</div>
					</a>
				</div>
			</div>

			<div
				class="logo-panel relative flex min-h-[18rem] items-center justify-center rounded-[1.25rem] border border-[var(--c-border)] bg-[var(--c-bg-primary)] p-6 shadow-[var(--shadow-sm)]"
			>
				<div class="absolute inset-0 opacity-70" aria-hidden="true"></div>
				<div class="relative text-center">
					<img
						class="mx-auto h-auto w-[11rem] drop-shadow-[0_14px_30px_rgba(0,0,0,0.16)] sm:w-[12.5rem]"
						ngSrc="logo.webp"
						alt="Wake Cup"
						width="720"
						height="720"
						priority
					/>
					<p class="mt-4 text-[12px] font-semibold uppercase tracking-[0.18em] text-[var(--c-secondary)]">
						Wake Cup
					</p>
				</div>
			</div>

			<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-1">
				<a
					class="contact-card block rounded-[1.1rem] border border-[var(--c-border)] bg-[var(--c-bg-primary)] p-4 shadow-[var(--shadow-sm)] transition-transform duration-200 hover:-translate-y-0.5"
					href="https://wakecup.itkamianets.com"
					rel="noreferrer"
					translate
					[translate]="{ ariaLabel: 'Open Wake Cup website' }"
				>
					<p class="text-sm font-semibold text-[var(--c-text-secondary)]">Website</p>
					<p class="mt-2 break-all text-sm leading-6 text-[var(--c-text-muted)]">
						wakecup.itkamianets.com
					</p>
				</a>

				<div
					class="contact-card block rounded-[1.1rem] border border-[var(--c-border)] bg-[var(--c-bg-primary)] p-4 shadow-[var(--shadow-sm)]"
				>
					<p class="text-sm font-semibold text-[var(--c-text-secondary)]">Instagram</p>
					<p class="mt-2 text-sm leading-6 text-[var(--c-text-muted)]">@wakecup</p>
				</div>

				<div
					class="contact-card block rounded-[1.1rem] border border-[var(--c-border)] bg-[var(--c-bg-primary)] p-4 shadow-[var(--shadow-sm)]"
				>
					<p class="text-sm font-semibold text-[var(--c-text-secondary)]">Takeaway</p>
					<p class="mt-2 text-sm leading-6 text-[var(--c-text-muted)]">
						<span [translate]="'Specialty coffee and pastries can be packed to go when available.'">
							{{ 'Specialty coffee and pastries can be packed to go when available.' }}
						</span>
					</p>
				</div>
			</div>
		</div>
	</section>
</main>
